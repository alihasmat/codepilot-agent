# --- LLM (pick one provider, set its key, and point CODEPILOT_MODEL at it) ---
# anthropic:claude-sonnet-4-5   | needs ANTHROPIC_API_KEY
# openai:gpt-4o                 | needs OPENAI_API_KEY
# google_genai:gemini-1.5-pro   | needs GOOGLE_API_KEY
CODEPILOT_MODEL=anthropic:claude-sonnet-4-5
ANTHROPIC_API_KEY=

# --- GitHub ---
# Classic token with `repo` scope, or fine-grained token with
# Contents, Issues, Pull requests: Read & write on the playground repo.
GITHUB_TOKEN=
# Filled in after running scripts/seed_playground.py
GITHUB_REPO=youruser/codepilot-playground

# --- Behaviour (defaults are fine for now) ---
POLL_INTERVAL_MINUTES=5
REPO_MAP_TOKEN_BUDGET=4000
